prefix_rule(pattern=["env"], decision="allow")
prefix_rule(pattern=["sleep", "2"], decision="allow")
prefix_rule(pattern=["sleep", "3"], decision="allow")
prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["cargo", "check"], decision="allow")
prefix_rule(pattern=["cargo", "clippy"], decision="allow")
prefix_rule(pattern=["cargo", "make"], decision="allow")
prefix_rule(pattern=["npm", "test"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["docker", "compose", "ps"], decision="allow")
prefix_rule(pattern=["docker", "compose", "logs"], decision="allow")
prefix_rule(pattern=["docker", "compose", "up", "-d"], decision="allow")
prefix_rule(pattern=["docker", "compose", "down"], decision="allow")
prefix_rule(pattern=["docker", "inspect", "--format"], decision="allow")
prefix_rule(pattern=["docker", "exec"], decision="allow")
prefix_rule(pattern=["docker", "images"], decision="allow")
prefix_rule(pattern=["docker", "info", "--format"], decision="allow")
prefix_rule(pattern=["docker", "volume", "ls"], decision="allow")
prefix_rule(pattern=["terraform", "init"], decision="allow")
prefix_rule(pattern=["terraform", "init", "-backend=false"], decision="allow")
prefix_rule(pattern=["terraform", "init", "-reconfigure"], decision="allow")
prefix_rule(pattern=["terraform", "validate"], decision="allow")
prefix_rule(pattern=["aws", "configure", "list"], decision="allow")
prefix_rule(pattern=["aws", "configure", "list-profiles"], decision="allow")
prefix_rule(pattern=["aws", "sts", "get-caller-identity"], decision="allow")
prefix_rule(pattern=["aws", "s3api", "get-bucket-location"], decision="allow")
prefix_rule(pattern=["uvx", "--from", "plane-mcp-server"], decision="allow")
prefix_rule(pattern=["python3", "$CODEX_HOME/skills/.system/skill-installer/scripts/list-skills.py"], decision="allow")
prefix_rule(pattern=["python3", "$CODEX_HOME/skills/.system/skill-installer/scripts/install-skill-from-github.py"], decision="allow")
prefix_rule(pattern=["npx", "-y", "skills", "find"], decision="allow")
prefix_rule(pattern=["sam", "local", "start-api"], decision="allow")
prefix_rule(pattern=["cargo", "run", "--manifest-path", "backend/Cargo.toml", "--bin", "local_api"], decision="allow")
prefix_rule(pattern=["curl", "-sS"], decision="allow")
